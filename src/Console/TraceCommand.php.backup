        $this->line($this->color("RESOURCE THIEF DETECTOR - COMPLETE SUITE", 'CYAN', 'BOLD'));
        $this->line($this->color(str_repeat('=', 50), 'CYAN'));
        $this->line("");
        $this->line($this->color("NORMAL MODE:", 'YELLOW', 'BOLD'));
        $this->line("  trace \"DB::table('users')->get()\"");
        $this->line("  trace \"User::find(1)\" --tree --level=5");
        $this->line("  trace --route /api/users");
        $this->line("  trace \"DB::table('users')->get()\" --memory");
        $this->line("");
        $this->line($this->color("PROFILE MODE:", 'YELLOW', 'BOLD'));
        $this->line("  trace --profile --profile-name=my_test --code=\"DB::table('users')->get()\"");
        $this->line("  trace --profile-name=my_test --fix=\"add index\" --code=\"...\"");
        $this->line("  trace --profile-name=my_test --compare");
        $this->line("  trace --profile-name=my_test --report --save");
        $this->line("  trace --load=my_test");
        $this->line("");
        $this->line($this->color("INTERACTIVE MODE:", 'YELLOW', 'BOLD'));
        $this->line("  trace");
        $this->line("  >>> profile my_test");
        $this->line("  >>> DB::table('users')->get()");
        $this->line("  >>> baseline");
        $this->line("  >>> fix \"add index\"");
        $this->line("  >>> compare");
        $this->line("  >>> report");
        $this->line("  >>> save");
        $this->line("  >>> exit");
        $this->line("");
        $this->line($this->color("OPTIONS:", 'YELLOW', 'BOLD'));
        $this->line("  --tree, -t       Display call tree");
        $this->line("  --level=N, -l=N  Tree depth (default: 3)");
        $this->line("  --details, -d    Show arguments");
        $this->line("  --warnings, -w   Show warnings only");
        $this->line("  --queries, -q    Show SQL only");
        $this->line("  --summary, -s    Show summary only");
        $this->line("  --memory         Deep memory analysis");
        $this->line("  --route          Execute as route");
        $this->line("  --params=JSON    Route parameters");
        $this->line("  --profile        Profile mode");
        $this->line("  --profile-name=N Profile name");
        $this->line("  --fix=NAME       Apply fix");
        $this->line("  --compare        Compare fixes");
        $this->line("  --report         Generate report");
        $this->line("  --save           Save profile");
        $this->line("  --load=NAME      Load profile");
        $this->line("  --push           Save checkpoint");
        $this->line("  --pop            Rollback checkpoint");
        $this->line("");
    }

    protected function color(string $text, string $color, ?string $style = null): string
    {
        $colors = [
            'BLACK' => '0;30',
            'DARK_GRAY' => '1;30',
            'RED' => '0;31',
            'LIGHT_RED' => '1;31',
            'GREEN' => '0;32',
            'LIGHT_GREEN' => '1;32',
            'BROWN' => '0;33',
            'YELLOW' => '1;33',
            'BLUE' => '0;34',
            'LIGHT_BLUE' => '1;34',
            'PURPLE' => '0;35',
            'LIGHT_PURPLE' => '1;35',
            'CYAN' => '0;36',
            'LIGHT_CYAN' => '1;36',
            'LIGHT_GRAY' => '0;37',
            'WHITE' => '1;37',
        ];

        $styles = [
            'RESET' => '0',
            'BOLD' => '1',
            'DIM' => '2',
            'UNDERLINE' => '4',
            'BLINK' => '5',
            'REVERSE' => '7',
            'HIDDEN' => '8',
        ];

        $codes = [];

        if ($style && isset($styles[$style])) {
            $codes[] = $styles[$style];
        }

        if ($color && isset($colors[$color])) {
            $codes[] = $colors[$color];
        }

        if (empty($codes)) {
            return $text;
        }

        return "\033[" . implode(';', $codes) . "m{$text}\033[0m";
    }

    // Add these three methods at the end of the class, just before the last closing brace.

    protected function traceRouteWithXdebug(string $uri, array $params = []): void
    {
        // Enable Xdebug Tracing if available
        if (function_exists('xdebug_start_trace')) {
            xdebug_start_trace('/tmp/trace.xt');
            $this->info($this->color("Xdebug tracing active", 'GREEN'));
        }

        // Create request
        $query = http_build_query($params);
        $fullUri = $uri . ($query ? '?' . $query : '');
        $request = Request::create($fullUri, 'GET');
        $request->server->set('HTTP_HOST', 'shadow.local');
        $request->server->set('SERVER_NAME', 'shadow.local');

        // Manual call tracking
        $controller = null;
        $action = null;

        // Find the route and controller
        $route = app('router')->getRoutes()->match($request);
        $action = $route->getActionName();

        if ($action && $action !== 'Closure') {
            $parts = explode('@', $action);
            $controllerClass = $parts[0];
            $method = $parts[1] ?? '__invoke';

            if (class_exists($controllerClass)) {
                $controller = app($controllerClass);
                $this->traceControllerCall($controller, $method, $route->parameters());
            }
        } else {
            // It's a closure
            $this->traceClosureExecution($route->getAction()['uses'] ?? $route->getAction()['controller'] ?? null);
        }

        // Stop Xdebug
        if (function_exists('xdebug_stop_trace')) {
            xdebug_stop_trace();
            $this->line($this->color("Trace saved to /tmp/trace.xt", 'DIM'));
            $this->line($this->color("Run: xdg-open /tmp/trace.xt", 'DIM'));
        }
    }

    protected function traceControllerCall($controller, string $method, array $parameters): void
    {
        $startTime = microtime(true);
        $startMemory = memory_get_usage();

        $reflection = new \ReflectionMethod($controller, $method);

        // Record the main call
        $this->recordCall($reflection->class . '::' . $reflection->name, $parameters, 0, $startTime);

        // Invoke the method
        $result = $reflection->invokeArgs($controller, $parameters);

        $endTime = microtime(true);
        $duration = round(($endTime - $startTime) * 1000, 2);
        $memoryUsed = round((memory_get_usage() - $startMemory) / 1024, 2);

        // Update the call with metrics
        foreach ($this->callTree as &$call) {
            if ($call['name'] === $reflection->class . '::' . $reflection->name && $call['depth'] === 0) {
                $call['duration_ms'] = $duration;
                $call['memory_kb'] = $memoryUsed;
                break;
            }
        }

        $this->displayCallTree((int)($this->option('level') ?? 3));
        $this->displayResult($result);
    }

    protected function traceClosureExecution($closure): void
    {
        if (!$closure instanceof \Closure) {
            $this->error("Cannot trace non-closure route");
            return;
        }

        $startTime = microtime(true);
        $startMemory = memory_get_usage();

        $reflection = new \ReflectionFunction($closure);
        $this->recordCall('Closure::__invoke', [], 0, $startTime);

        $result = $closure();

        $endTime = microtime(true);
        $duration = round(($endTime - $startTime) * 1000, 2);
        $memoryUsed = round((memory_get_usage() - $startMemory) / 1024, 2);

        foreach ($this->callTree as &$call) {
            if ($call['name'] === 'Closure::__invoke' && $call['depth'] === 0) {
                $call['duration_ms'] = $duration;
                $call['memory_kb'] = $memoryUsed;
                break;
            }
        }

        $this->displayCallTree((int)($this->option('level') ?? 3));
        $this->displayResult($result);
    }
}
